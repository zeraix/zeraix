<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- entitlementsInherit: electron-builder uses this to sign the "nested-in-bundle" binaries (Chromium
       renderer/GPU helpers, node-pty, and the qemu-system-* / qemu-img / qemu *.dylib in resources).
       Note: llama is not in the bundle — at runtime it's downloaded from a CDN (llama.cpp GitHub release builds)
       into userData, carries its own ad-hoc signature with no quarantine attribute, and runs as a standalone
       child process unaffected by this app's signing/notarization. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!-- Disable library validation: needed by native modules such as node-pty plus qemu loading its bundled dylibs. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- HVF: actually used only by qemu-system-* (sandbox hardware acceleration); the other nested binaries
       carry it but don't use it, which is harmless. This way electron-builder's normal signing preserves the
       entitlement, with no need for an afterSign re-sign (which would otherwise break the post-notarization seal). -->
  <key>com.apple.security.hypervisor</key>
  <true/>
</dict>
</plist>
