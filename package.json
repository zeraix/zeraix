{
  "name": "Zeraix",
  "version": "1.2.2",
  "private": true,
  "main": "electron/main.mjs",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "overrides": {
      "@electron/get": "5.0.0"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "npx tsc --noEmit",
    "preview": "serve -s operease-zeraix -p 9999",
    "prod-test": "next build && next start -p 9999",
    "lint": "eslint",
    "electron": "electron .",
    "gen:google": "node scripts/gen-google-defaults.mjs",
    "preelectron:dev": "node scripts/gen-google-defaults.mjs",
    "electron:dev": "concurrently -k \"next dev\" \"wait-on tcp:3000 && electron .\"",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "bundle:bin:mac": "node scripts/bundle-bin-mac.mjs",
    "bundle:bin:win": "node scripts/bundle-bin-win.mjs",
    "publish:llama": "node scripts/publish-llama.mjs",
    "download:bin:win": "node scripts/download-bin-win.mjs",
    "download:bin:mac": "node scripts/download-bin-mac.mjs",
    "build:rootfs": "node scripts/build-rootfs.mjs",
    "publish:rootfs": "node scripts/publish-rootfs.mjs",
    "image:publish": "npm run build:rootfs && npm run publish:rootfs",
    "dist:win": "npm run download:bin:win && cross-env NEXT_PUBLIC_APP_EDITION=intl next build && npm run gen:google && cross-env NEXT_PUBLIC_APP_EDITION=intl electron-builder --win -p never",
    "dist:win:cn": "npm run download:bin:win && cross-env NEXT_PUBLIC_APP_EDITION=cn next build && npm run gen:google && cross-env NEXT_PUBLIC_APP_EDITION=cn electron-builder --win -p never",
    "dist:mac": "npm run download:bin:mac && cross-env NEXT_PUBLIC_APP_EDITION=intl next build && npm run gen:google && cross-env NEXT_PUBLIC_APP_EDITION=intl electron-builder --mac -p never",
    "dist:mac:cn": "npm run download:bin:mac && cross-env NEXT_PUBLIC_APP_EDITION=cn next build && npm run gen:google && cross-env NEXT_PUBLIC_APP_EDITION=cn electron-builder --mac -p never",
    "dist:dir": "npm run download:bin:mac && cross-env NEXT_PUBLIC_APP_EDITION=intl next build && npm run gen:google && cross-env NEXT_PUBLIC_APP_EDITION=intl electron-builder --dir"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "4.7.0",
    "@radix-ui/react-visually-hidden": "^1.2.6",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/markdown-it": "14.1.2",
    "@types/prismjs": "1.26.6",
    "@uiw/react-markdown-preview": "^5.2.1",
    "@uiw/react-md-editor": "4.1.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "@xyflow/react": "12.10.2",
    "@zzcpt/zztool": "^2.6.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "6.8.9",
    "framer-motion": "12.38.0",
    "highlight.js": "11.11.1",
    "js-tiktoken": "1.0.21",
    "lucide-react": "^0.577.0",
    "markdown-it": "14.1.1",
    "nertc-web-sdk": "^5.8.34",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nim-web-sdk-ng": "^10.9.76",
    "node-pty": "1.1.0",
    "openai": "6.44.0",
    "prismjs": "1.30.0",
    "puppeteer-core": "^25.2.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4",
    "react-simple-code-editor": "0.14.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "0.184.0",
    "vaul": "1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "4.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "adm-zip": "0.5.18",
    "ali-oss": "6.23.0",
    "concurrently": "10.0.3",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "raw-loader": "4.0.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "9.0.10"
  },
  "engines": {
    "node": ">=20.9"
  }
}
