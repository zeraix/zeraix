# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/dist
/build
/dist-electron
/Zeraix
/.claude
/.cursor
/.zeraix
/docs
/.vscode
/.agents

# electron-builder output
/dist-electron

# testing
/coverage

# next.js
/.next/
/out/
/operease-zeraix

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# includ .env.example
.env
.env.development
.env.production
.env.staging
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# QEMU 沙箱预置二进制（发版时准备，不入库）；rootfs 首次运行下载到 ~/.operease/vm
resources/bin/*/
resources/qemu/*/

# Google OAuth 兜底凭据（构建时由本机 .env 生成，勿提交）
electron/services/google-defaults.json

build-mac.sh