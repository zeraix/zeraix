# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/dist
/build
/dist-electron
/Zeraix
/.claude
/.cursor
/.zeraix
/docs
/.vscode
/.agents

# electron-builder output
/dist-electron

# testing
/coverage

# next.js
/.next/
/out/
/operease-zeraix

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# includ .env.example
.env
.env.development
.env.production
.env.staging
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# QEMU sandbox preinstalled binaries (prepared at release time, not committed); rootfs is downloaded to ~/.operease/vm on first run
resources/bin/*/
resources/qemu/*/

# Google OAuth fallback credentials (generated locally from .env during build; do not commit)
electron/services/google-defaults.json

build-mac.sh